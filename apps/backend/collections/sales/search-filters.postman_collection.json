              "  const partial = pm.environment.get('partialCarbyneId1');",
              "  const found = body.data.some(inc => inc.carbyne_id.toString().includes(partial));",
              "  pm.expect(found, 'Al menos un resultado debe contener carbyne_id con ' + partial).to.be.true;",
              "});"
            ],
            "type": "text/javascript"
          }
        }
