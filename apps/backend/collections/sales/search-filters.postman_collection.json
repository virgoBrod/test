              "pm.test('Busqueda parcial por CarbyneId retorna al menos 1 resultado', () => {",
              "  const body = pm.response.json();",
              "  pm.expect(body.data).to.be.an('array');",
              "  pm.expect(body.total).to.be.at.least(1);",
              "});",
