        "url": {
          "raw": "{{webBaseUrl}}/api/broad?timeRangeSelectValues=hoy&myCases=0&callTime[]=40&callTime[]=1800&startTime=00:00:40&endTime=00:30:00&rangeSelected=C&limit=50&page=1&search={{partialCarbyneId1}}",
          "host": ["{{webBaseUrl}}"],
          "path": ["api", "broad"],
          "query": [
            { "key": "timeRangeSelectValues", "value": "hoy" },
            { "key": "myCases", "value": "0" },
            { "key": "callTime[]", "value": "40" },
            { "key": "callTime[]", "value": "1800" },
            { "key": "startTime", "value": "00:00:40" },
            { "key": "endTime", "value": "00:30:00" },
            { "key": "rangeSelected", "value": "C" },
            { "key": "limit", "value": "50" },
            { "key": "page", "value": "1" },
            { "key": "search", "value": "{{partialCarbyneId1}}" }
          ]
        }
      }
    },
