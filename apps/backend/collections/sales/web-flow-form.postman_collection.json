              "",
              "pm.test('Campos actualizados coinciden con lo enviado en UpdateForm', () => {",
              "  const updateBody = JSON.parse(pm.environment.get('_updateBody'));",
              "  const getReport = pm.response.json().report;",
              "  pm.expect(getReport.callerInvolved).to.eql(updateBody.callerInvolved, 'callerInvolved debe coincidir');",
              "  pm.expect(getReport.injured).to.eql(updateBody.injured, 'injured debe coincidir');",
              "  pm.expect(getReport.homeless).to.eql(updateBody.homeless, 'homeless debe coincidir');",
              "  pm.expect(getReport.died).to.eql(updateBody.died, 'died debe coincidir');",
              "  pm.expect(getReport.vehiclesCanBeMoved).to.eql(updateBody.vehiclesCanBeMoved, 'vehiclesCanBeMoved debe coincidir');",
              "});",
              "",
              "pm.test('involvedItems actualizados correctamente', () => {",
              "  const updateBody = JSON.parse(pm.environment.get('_updateBody'));",
              "  const getReport = pm.response.json().report;",
              "  pm.expect(getReport.involvedItems).to.be.an('array');",
              "  pm.expect(getReport.involvedItems.length).to.eql(updateBody.involvedItems.length, 'cantidad de involvedItems debe coincidir');",
              "  updateBody.involvedItems.forEach((expected, i) => {",
              "    pm.expect(getReport.involvedItems[i].itemType).to.eql(expected.itemType, 'itemType debe coincidir en item ' + i);",
              "    pm.expect(getReport.involvedItems[i].quantity).to.eql(expected.quantity, 'quantity debe coincidir en item ' + i);",
              "    pm.expect(JSON.stringify(getReport.involvedItems[i].plates)).to.eql(JSON.stringify(expected.plates), 'plates deben coincidir en item ' + i);",
              "  });",
              "});",
              "",
              "pm.test('updatedAt cambio despues del update', () => {",
              "  const createReport = JSON.parse(pm.environment.get('_createReport'));",
              "  const getReport = pm.response.json().report;",
              "  pm.expect(getReport.updatedAt).to.not.eql(createReport.updatedAt, 'updatedAt debe ser diferente al original');",
              "});"
            ],
            "type": "text/javascript"
          }
        }
