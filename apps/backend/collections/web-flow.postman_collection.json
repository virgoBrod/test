{
  "info": {
    "name": "Web Flow",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Login",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status 200', () => {",
              "  pm.response.to.have.status(200);",
              "});",
              "",
              "pm.test('Retorna token y guarda authToken', () => {",
              "  const body = pm.response.json();",
              "  pm.expect(body.token).to.be.a('string');",
              "  pm.environment.set('webAuthToken', body.token);",
              "});",
              "",
              "pm.test('Retorna datos del calltaker', () => {",
              "  const body = pm.response.json();",
              "  pm.expect(body.idCallTaker).to.exist;",
              "  pm.expect(body.fullName).to.be.a('string');",
              "  pm.expect(body.email).to.be.a('string');",
              "  pm.expect(body.role).to.be.a('string');",
              "  pm.environment.set('webCallTakerId', body.idCallTaker);",
              "});",
              "",
              "pm.test('Retorna datos de estacion y proyecto', () => {",
              "  const body = pm.response.json();",
              "  pm.expect(body.stationNumber).to.be.a('number');",
              "  pm.expect(body.project).to.be.a('string');",
              "  pm.expect(body.city).to.be.a('string');",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"{{webEmail}}\",\n  \"password\": \"{{webPassword}}\"\n}",
          "options": {
            "raw": {
              "language": "json"
            }
          }
        },
        "url": {
          "raw": "{{webBaseUrl}}/auth",
          "host": ["{{webBaseUrl}}"],
          "path": ["auth"]
        }
      }
    },
    {
      "name": "GetGrouped",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status 200', () => {",
              "  pm.response.to.have.status(200);",
              "});",
              "",
              "pm.test('Retorna array de grupos', () => {",
              "  const body = pm.response.json();",
              "  pm.expect(body).to.be.an('array');",
              "  pm.expect(body.length).to.be.above(0);",
              "});",
              "",
              "pm.test('Estructura de grupo correcta', () => {",
              "  const body = pm.response.json();",
              "  const first = body[0];",
              "  pm.expect(first.item).to.be.a('string');",
              "  pm.expect(first.subitems).to.be.an('array');",
              "  if (first.subitems.length > 0) {",
              "    pm.expect(first.subitems[0].id).to.be.a('number');",
              "    pm.expect(first.subitems[0].name).to.be.a('string');",
              "  }",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{webAuthToken}}"
          }
        ],
        "url": {
          "raw": "{{webBaseUrl}}/api/incidents/grouped",
          "host": ["{{webBaseUrl}}"],
          "path": ["api", "incidents", "grouped"]
        }
      }
    },
    {
      "name": "GetDepartment",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status 200', () => {",
              "  pm.response.to.have.status(200);",
              "});",
              "",
              "pm.test('Retorna array de departamentos', () => {",
              "  const body = pm.response.json();",
              "  pm.expect(body).to.be.an('array');",
              "});",
              "",
              "pm.test('Estructura de departamento correcta', () => {",
              "  const body = pm.response.json();",
              "  if (body.length > 0) {",
              "    pm.expect(body[0].id).to.be.a('number');",
              "    pm.expect(body[0].nombre).to.be.a('string');",
              "  }",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{webAuthToken}}"
          }
        ],
        "url": {
          "raw": "{{webBaseUrl}}/api/department?region=",
          "host": ["{{webBaseUrl}}"],
          "path": ["api", "department"],
          "query": [
            {
              "key": "region",
              "value": ""
            }
          ]
        }
      }
    },
    {
      "name": "GetZones",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status 200', () => {",
              "  pm.response.to.have.status(200);",
              "});",
              "",
              "pm.test('Retorna array de zonas', () => {",
              "  const body = pm.response.json();",
              "  pm.expect(body).to.be.an('array');",
              "});",
              "",
              "pm.test('Estructura de zona correcta', () => {",
              "  const body = pm.response.json();",
              "  if (body.length > 0) {",
              "    pm.expect(body[0].id).to.be.a('number');",
              "    pm.expect(body[0].nombre).to.be.a('string');",
              "  }",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{webAuthToken}}"
          }
        ],
        "url": {
          "raw": "{{webBaseUrl}}/api/locations/zones",
          "host": ["{{webBaseUrl}}"],
          "path": ["api", "locations", "zones"]
        }
      }
    },
    {
      "name": "GetIncidents",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status 200', () => {",
              "  pm.response.to.have.status(200);",
              "});",
              "",
              "pm.test('Retorna paginacion correcta', () => {",
              "  const body = pm.response.json();",
              "  pm.expect(body.total).to.be.a('number');",
              "  pm.expect(body.currentPage).to.be.a('number');",
              "  pm.expect(body.totalPages).to.be.a('number');",
              "});",
              "",
              "pm.test('Retorna array de incidents', () => {",
              "  const body = pm.response.json();",
              "  pm.expect(body.data).to.be.an('array');",
              "});",
              "",
              "pm.test('Estructura de incident correcta', () => {",
              "  const body = pm.response.json();",
              "  if (body.data.length > 0) {",
              "    const incident = body.data[0];",
              "    pm.expect(incident.id).to.be.a('number');",
              "    pm.expect(incident.phone).to.be.a('string');",
              "    pm.expect(incident.case_state).to.be.a('string');",
              "    pm.expect(incident.type).to.be.a('string');",
              "  }",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{webAuthToken}}"
          }
        ],
        "url": {
          "raw": "{{webBaseUrl}}/api/broad?timeRangeSelectValues=hoy&myCases=0&callTime[]=40&callTime[]=1800&startTime=00:00:40&endTime=00:30:00&rangeSelected=C&limit=50&page=1&search=",
          "host": ["{{webBaseUrl}}"],
          "path": ["api", "broad"],
          "query": [
            { "key": "timeRangeSelectValues", "value": "hoy" },
            { "key": "myCases", "value": "0" },
            { "key": "callTime[]", "value": "40" },
            { "key": "callTime[]", "value": "1800" },
            { "key": "startTime", "value": "00:00:40" },
            { "key": "endTime", "value": "00:30:00" },
            { "key": "rangeSelected", "value": "C" },
            { "key": "limit", "value": "50" },
            { "key": "page", "value": "1" },
            { "key": "search", "value": "" }
          ]
        }
      }
    },
    {
      "name": "Logout",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status 200', () => {",
              "  pm.response.to.have.status(200);",
              "});",
              "",
              "pm.test('Retorna message de sesion finalizada', () => {",
              "  const body = pm.response.json();",
              "  pm.expect(body.message).to.be.a('string');",
              "});",
              "",
              "pm.test('Token limpiado', () => {",
              "  pm.environment.unset('webAuthToken');",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{webAuthToken}}"
          }
        ],
        "url": {
          "raw": "{{webBaseUrl}}/logout",
          "host": ["{{webBaseUrl}}"],
          "path": ["logout"]
        }
      }
    }
  ]
}
