{
  "info": {
    "name": "Auth — Web",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Login",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status 200', () => {",
              "  pm.response.to.have.status(200);",
              "});",
              "",
              "pm.test('Retorna token', () => {",
              "  pm.expect(pm.response.json().token).to.be.a('string');",
              "});",
              "",
              "pm.test('Retorna datos del calltaker', () => {",
              "  const body = pm.response.json();",
              "  pm.expect(body.idCallTaker).to.exist;",
              "  pm.expect(body.fullName).to.be.a('string');",
              "  pm.expect(body.email).to.be.a('string');",
              "  pm.expect(body.role).to.be.a('string');",
              "});",
              "",
              "pm.test('Retorna stationNumber y project', () => {",
              "  const body = pm.response.json();",
              "  pm.expect(body.stationNumber).to.be.a('number');",
              "  pm.expect(body.project).to.eql('med');",
              "  pm.expect(body.agency).to.be.a('string');",
              "});",
              "",
              "const _login = pm.response.json();",
              "pm.environment.set('webAuthToken', _login.token);",
              "pm.environment.set('webCallTakerId', _login.idCallTaker);",
              "pm.environment.set('webStationNumber', _login.stationNumber);"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"{{webEmail}}\",\n  \"password\": \"{{webPassword}}\"\n}",
          "options": {
            "raw": {
              "language": "json"
            }
          }
        },
        "url": {
          "raw": "https://medellin.inovisec.com/auth/login",
          "protocol": "https",
          "host": ["medellin", "inovisec", "com"],
          "path": ["auth", "login"]
        }
      }
    },
    {
      "name": "Logout",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status 200', () => {",
              "  pm.response.to.have.status(200);",
              "});",
              "",
              "pm.test('Retorna ok true', () => {",
              "  const body = pm.response.json();",
              "  pm.expect(body.ok).to.eql(true);",
              "});",
              "",
              "pm.test('Token limpiado', () => {",
              "  pm.environment.unset('webAuthToken');",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{webAuthToken}}"
          }
        ],
        "url": {
          "raw": "https://medellin.inovisec.com/auth/logout",
          "protocol": "https",
          "host": ["medellin", "inovisec", "com"],
          "path": ["auth", "logout"]
        }
      }
    }
  ]
}
